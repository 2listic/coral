// For format details, see https://aka.ms/vscode-remote/devcontainer.json or this file's README at:
// https://github.com/microsoft/vscode-dev-containers/tree/v0.122.1/containers/docker-existing-dockerfile
{
	"name": "deal.II image container",
	// Update the 'dockerFile' property if you aren't using the standard 'Dockerfile' filename.
	"image": "dealii/dealii:v9.6.0-noble",
	// Add the IDs of extensions you want installed when the container is created.
	"extensions": [
		"alefragnani.project-manager",
		"davydden.dealii-prm",
		"johnpapa.vscode-peacock",
		"ms-vscode.cmake-tools",
		"ms-vscode.cpptools",
		"shan.code-settings-sync",
		"openai.chatgpt",
		"matepek.vscode-catch2-test-adapter"
	],
	"settings": {
		"cmake.buildDirectory": "${workspaceFolder}/build-container",
		"cmake.configureArgs": [
			"-DCMAKE_EXPORT_COMPILE_COMMANDS:BOOL=TRUE"
		]
	},
	"remoteUser": "dealii"
}
